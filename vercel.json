{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/**"
    },
    "api/rooms/**/*.ts": {
      "includeFiles": "public/data/cards.json"
    }
  }
}
